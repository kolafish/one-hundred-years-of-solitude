<view class="page">
  <view class="masthead">
    <view>
      <view class="kicker">中年的百年孤独</view>
      <view class="title">译本盲选</view>
    </view>
    <view class="progress">{{currentNumber}} / {{sessionTotal}}</view>
  </view>

  <view wx:if="{{mode === 'quiz'}}" class="quiz">
    <view class="meta">
      <text>第 {{currentQuestion.chapterOrder}} 章</text>
      <text>热度 {{currentQuestion.highlightCount}}</text>
    </view>

    <view class="cue" wx:if="{{currentQuestion.cue}}">{{currentQuestion.cue}}</view>
    <view class="prompt">请选择你更喜欢的版本</view>

    <view class="options">
      <view
        wx:for="{{currentQuestion.options}}"
        wx:key="key"
        class="option {{item.selected ? 'selected' : ''}}"
        hover-class="option-hover"
        data-key="{{item.key}}"
        bindtap="selectOption"
      >
        <view class="option-label">{{item.label}}</view>
        <view class="option-text">{{item.text}}</view>
      </view>
    </view>

    <view class="actions quiz-actions">
      <button
        class="ghost previous {{currentIndex === 0 ? 'disabled' : ''}}"
        disabled="{{currentIndex === 0}}"
        bindtap="previousQuestion"
      >上一题</button>
      <button class="ghost quiz-restart" bindtap="restartSession">重来</button>
    </view>
  </view>

  <view wx:else class="result">
    <view class="result-summary">
      <view class="result-title">本轮完成</view>
      <view class="result-count">{{answers.length}} / {{sessionTotal}}</view>
      <view class="stats">
        <view>
          <text class="stats-number">{{stats.totalSessions}}</text>
          <text class="stats-label">累计轮次</text>
        </view>
        <view>
          <text class="stats-number">{{stats.totalAnswers}}</text>
          <text class="stats-label">累计选择</text>
        </view>
      </view>
    </view>

    <view class="translator-results">
      <view class="section-title">译者选择统计</view>
      <view
        wx:for="{{resultRows}}"
        wx:key="id"
        class="translator-row"
      >
        <view class="translator-line">
          <text class="translator-name">{{item.name}}</text>
          <text class="translator-count">本轮 {{item.roundVotes}} / {{item.roundAppearances}} · 累计 {{item.totalVotes}} / {{item.totalAppearances}}</text>
        </view>
        <view class="translator-track">
          <view class="translator-bar" style="width: {{item.roundPercent}}%; background: {{item.color}};"></view>
        </view>
        <view class="translator-percent">选中率 本轮 {{item.roundPercentText}} · 累计 {{item.totalPercentText}}</view>
      </view>
    </view>

    <view class="result-actions">
      <button class="ghost compact" open-type="share">分享</button>
      <button class="ghost compact" bindtap="copyStats">复制统计</button>
      <button class="ghost compact" bindtap="clearStats">清空</button>
    </view>
    <button class="primary wide restart-primary" bindtap="restartSession">再来一次</button>
  </view>
</view>
