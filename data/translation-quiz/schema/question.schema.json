{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kolafish.github.io/one-hundred-years-of-solitude/data/translation-quiz/schema/question.schema.json",
  "title": "One Hundred Years of Solitude Translation Quiz Questions",
  "type": "object",
  "required": ["schemaVersion", "source", "questions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "source": {
      "type": "object",
      "required": ["anchorFile", "versionFile", "generatedAt"],
      "additionalProperties": false,
      "properties": {
        "anchorFile": {"type": "string"},
        "versionFile": {"type": "string"},
        "generatedAt": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "questions": {
      "type": "array",
      "items": {"$ref": "#/$defs/question"}
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "required": [
        "id",
        "chapterOrder",
        "chapterUid",
        "range",
        "rank",
        "highlightCount",
        "anchor",
        "options",
        "quality"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ch[0-9]{2}-[0-9]{3}$"
        },
        "chapter": {"type": "string"},
        "chapterOrder": {"type": "integer", "minimum": 1, "maximum": 20},
        "chapterUid": {"type": "integer"},
        "range": {"type": "string", "pattern": "^[0-9]+-[0-9]+$"},
        "rank": {"type": "integer", "minimum": 1},
        "cue": {"type": "string"},
        "themes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "highlightCount": {"type": "integer", "minimum": 0},
        "anchor": {
          "type": "object",
          "required": ["versionId", "text"],
          "additionalProperties": false,
          "properties": {
            "versionId": {"type": "string"},
            "text": {"type": "string", "minLength": 1}
          }
        },
        "options": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {"$ref": "#/$defs/option"}
        },
        "quality": {
          "type": "object",
          "required": ["status", "minConfidence", "usableVersionIds"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ready", "review", "disabled"]
            },
            "minConfidence": {"type": "number", "minimum": 0, "maximum": 1},
            "usableVersionIds": {
              "type": "array",
              "items": {"type": "string"}
            },
            "warnings": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "option": {
      "type": "object",
      "required": ["versionId", "text", "confidence", "status"],
      "additionalProperties": false,
      "properties": {
        "versionId": {"type": "string"},
        "text": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "status": {
          "type": "string",
          "enum": ["aligned", "needs_review", "unusable"]
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "keywordRecall": {"type": "number", "minimum": 0, "maximum": 1},
            "lengthRatio": {"type": "number", "minimum": 0},
            "positionDelta": {"type": "number", "minimum": 0}
          }
        },
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "normalized": {"type": "boolean"},
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "chapterOrder": {"type": "integer"},
            "paragraphIndex": {"type": "integer"},
            "sentenceIndex": {
              "type": "array",
              "items": {"type": "integer"}
            }
          }
        }
      }
    }
  }
}
